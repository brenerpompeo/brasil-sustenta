# ── Supabase (server-side) ──────────────────────────────────────────────────
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=sua-chave-secreta-forte-32-chars

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:[SENHA]@db.[PROJETO].supabase.co:5432/postgres

# ── LLM ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── Client (VITE_ — expostas ao browser em build time) ──────────────────────
VITE_APP_TITLE=Brasil Sustenta
VITE_APP_LOGO=/favicon.svg
# URL de origem usada no fluxo OAuth (em preview/prod: URL pública do deploy)
VITE_OAUTH_PORTAL_URL=http://localhost:3000
# Token público Mapbox para TerritoryMap e AddressSearch
VITE_MAPBOX_ACCESS_TOKEN=
# Analytics Umami (opcional)
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
